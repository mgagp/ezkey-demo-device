# Optional: copy to .env only when you want to override Compose defaults.
#
# docker-compose.yml already defaults EZKEY_AUTH_API_URL to Exp1:
#   https://exp1-auth-api.ezkey.org
#
# Uncomment below to point at a local Auth API (e.g. clean-start on the host) instead:
# EZKEY_AUTH_API_URL=http://host.docker.internal:8080
