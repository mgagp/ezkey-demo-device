# Copy to .env and adjust. Used by docker-compose.yml for the running container.

# Base URL of the Ezkey Auth API as seen FROM INSIDE the Docker container.
# Example: Exp1 hosted stack (public Auth API).
EZKEY_AUTH_API_URL=https://exp1-auth-api.ezkey.org

# For a local clean-start Auth API on your machine instead, use e.g.:
# EZKEY_AUTH_API_URL=http://host.docker.internal:8080
